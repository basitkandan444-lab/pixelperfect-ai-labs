# Example environment configuration. Copy to `.env` for local development.
# `.env` is git-ignored — never commit real values.
#
# All variables below are OPTIONAL: the app boots without them. Malformed values
# (wrong format) fail validation in src/lib/env.ts.

# --- Server secrets (never exposed to the browser) ---------------------------
# AI enhancement gateway key. Without it, /api/enhance-image returns
# `ai_unconfigured` instead of enhancing. Set via the Lovable secrets store in
# production — do NOT commit a real key here.
LOVABLE_API_KEY=

# --- Client config (VITE_*, shipped in the browser bundle — public) ----------
# Google Analytics 4 measurement ID, e.g. G-XXXXXXXXXX
VITE_GA4_ID=

# Microsoft Clarity project ID
VITE_CLARITY_ID=

# Extra Google Search Console verification token
VITE_GSC_VERIFICATION=

# Browser-cache policy for first-party static assets served from /public.
#
# Hashed build output under /assets/* is already served immutable (1 year) by
# the platform, so it is intentionally omitted here. These rules cover the
# non-hashed static files the build pipeline copies verbatim from /public,
# which otherwise ship with no Cache-Control header.

# Fonts never change under the same filename -> safe to cache immutably.
/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# Before/after gallery imagery is stable content -> long-term cache.
/gallery/*
  Cache-Control: public, max-age=31536000, immutable

# Icons and social/share imagery -> long-term cache with revalidation window.
/favicon.ico
  Cache-Control: public, max-age=31536000, immutable
/icon.png
  Cache-Control: public, max-age=31536000, immutable
/apple-touch-icon.png
  Cache-Control: public, max-age=31536000, immutable
/og-image.jpg
  Cache-Control: public, max-age=2592000

# App manifest and text metadata may change between deploys -> shorter cache.
/site.webmanifest
  Cache-Control: public, max-age=86400
/robots.txt
  Cache-Control: public, max-age=86400
/llms.txt
  Cache-Control: public, max-age=86400
